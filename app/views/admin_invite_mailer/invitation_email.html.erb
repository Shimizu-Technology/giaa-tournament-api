<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>You've been invited to the Golf Tournament Admin Portal</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f6f9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">

  <!-- Email wrapper -->
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f4f6f9;">
    <tr>
      <td style="padding: 32px 16px;">

        <!-- Email card -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 560px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background-color: #1e3a5f; padding: 40px 40px 36px; text-align: center;">
              <!-- Golf icon + title -->
              <div style="margin-bottom: 12px;">
                <span style="display: inline-block; width: 48px; height: 48px; background-color: rgba(255,255,255,0.15); border-radius: 50%; line-height: 48px; font-size: 24px;">⛳</span>
              </div>
              <h1 style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 700; letter-spacing: 0.5px; line-height: 1.3;">
                Golf Tournament<br>
                <span style="font-size: 14px; font-weight: 400; opacity: 0.85; letter-spacing: 1px; text-transform: uppercase;">Admin Portal</span>
              </h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 40px 40px 32px;">

              <!-- Invite heading -->
              <h2 style="margin: 0 0 16px; color: #1e3a5f; font-size: 26px; font-weight: 700; line-height: 1.2;">
                You've been invited! 🎉
              </h2>

              <p style="margin: 0 0 20px; color: #4a5568; font-size: 16px; line-height: 1.6;">
                Hi<% if @admin.name.present? %> <%= @admin.name.split(' ').first %><% end %>,
              </p>

              <p style="margin: 0 0 24px; color: #4a5568; font-size: 16px; line-height: 1.6;">
                <strong style="color: #1e3a5f;"><%= @invited_by_name %></strong> has invited you to join the tournament admin portal. You'll have access to manage tournaments, registrations, golfer data, and more.
              </p>

              <!-- CTA Button -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0 0 28px;">
                <tr>
                  <td style="border-radius: 8px; background-color: #1e3a5f;">
                    <a href="<%= @frontend_url %>"
                       style="display: inline-block; padding: 14px 32px; color: #ffffff; font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 8px; letter-spacing: 0.3px;">
                      Get Started →
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Instructions -->
              <div style="background-color: #f8fafc; border-left: 4px solid #1e3a5f; border-radius: 0 8px 8px 0; padding: 16px 20px; margin-bottom: 8px;">
                <p style="margin: 0; color: #4a5568; font-size: 14px; line-height: 1.6;">
                  <strong style="color: #1e3a5f;">How to get started:</strong><br>
                  Click the button above, then sign up or log in with this email address (<strong><%= @admin.email %></strong>) to access the admin dashboard.
                </p>
              </div>

            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td style="padding: 0 40px;">
              <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 0;">
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 24px 40px 32px; text-align: center;">
              <p style="margin: 0 0 4px; color: #a0aec0; font-size: 12px;">
                This invitation was sent to <strong><%= @admin.email %></strong>
              </p>
              <p style="margin: 0; color: #a0aec0; font-size: 12px;">
                Powered by <strong style="color: #718096;">Shimizu Technology</strong>
              </p>
            </td>
          </tr>

        </table>

        <!-- Bottom note -->
        <p style="text-align: center; color: #a0aec0; font-size: 11px; margin: 20px 0 0;">
          © <%= Time.current.year %> Shimizu Technology · Guam
        </p>

      </td>
    </tr>
  </table>

</body>
</html>
